<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="DeadGiveaway" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>

    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        document.addEventListener("DOMContentLoaded", () => {
          document
            .querySelectorAll("button[data-phx-theme]")
            .forEach((el) => {
              el.addEventListener("click", () => {
                setTheme(el.dataset.phxTheme)
              })
            })
        })
      })();
    </script>
  </head>

  <body>
    {@inner_content}

    <%!-- Always-accessible audio settings (#19): a transparent gear fixed top-right on
          every screen (home, lobby, gameplay). The gear toggles the panel; app.js
          (mountAudioSettings) wires these controls to the shared audio shell, so a change
          takes effect live — including mid-round. The On/Off + sliders use the ids
          volume.mjs binds to; this is the single entry point (the old homepage Sound card
          is gone). --%>
    <div class="fixed right-4 top-4 z-30">
      <button
        id="audio-gear"
        type="button"
        aria-label="Audio settings"
        class="flex h-10 w-10 items-center justify-center rounded-full bg-transparent text-slate-300/70 transition hover:bg-white/10 hover:text-white"
      >
        <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
          <path
            d="M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z"
            stroke="currentColor"
            stroke-width="1.6"
          />
          <path
            d="M19.4 13a1.7 1.7 0 0 0 .34 1.87l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1.03 1.56V19a2 2 0 1 1-4 0v-.09A1.7 1.7 0 0 0 8.5 17.3a1.7 1.7 0 0 0-1.87.34l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.7 1.7 0 0 0 .34-1.87 1.7 1.7 0 0 0-1.56-1.03H2.5a2 2 0 1 1 0-4h.09A1.7 1.7 0 0 0 4.7 8.5a1.7 1.7 0 0 0-.34-1.87l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.7 1.7 0 0 0 1.87.34H9a1.7 1.7 0 0 0 1.03-1.56V2.5a2 2 0 1 1 4 0v.09a1.7 1.7 0 0 0 1.03 1.56 1.7 1.7 0 0 0 1.87-.34l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.7 1.7 0 0 0-.34 1.87V9a1.7 1.7 0 0 0 1.56 1.03h.09a2 2 0 1 1 0 4h-.09a1.7 1.7 0 0 0-1.56 1.03Z"
            stroke="currentColor"
            stroke-width="1.6"
          />
        </svg>
      </button>

      <div
        id="audio-panel"
        hidden
        class="absolute right-0 mt-2 w-64 rounded-xl bg-[#10162e]/95 p-4 text-left shadow-2xl ring-1 ring-white/10 backdrop-blur-sm"
      >
        <div class="mb-3 flex items-center justify-between">
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
            Sound
          </span>
          <div class="flex items-center gap-3 text-sm text-slate-300">
            <label class="flex items-center gap-1">
              <input type="radio" name="sound" value="on" class="accent-emerald-500" /> On
            </label>
            <label class="flex items-center gap-1">
              <input type="radio" name="sound" value="off" class="accent-emerald-500" checked />
              Off
            </label>
          </div>
        </div>

        <div id="vol-sliders" class="space-y-2">
          <label class="flex items-center gap-2 text-xs text-slate-400">
            <span class="w-12 shrink-0">Master</span>
            <input
              id="vol-master"
              type="range"
              min="0"
              max="100"
              class="w-full accent-emerald-500"
            />
            <span id="vol-master-val" class="w-8 text-right tabular-nums text-slate-500"></span>
          </label>
          <label class="flex items-center gap-2 text-xs text-slate-400">
            <span class="w-12 shrink-0">SFX</span>
            <input id="vol-sfx" type="range" min="0" max="100" class="w-full accent-emerald-500" />
            <span id="vol-sfx-val" class="w-8 text-right tabular-nums text-slate-500"></span>
          </label>
        </div>
      </div>
    </div>
  </body>
</html>
